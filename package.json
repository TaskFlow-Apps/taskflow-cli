{
  "name": "@taskflowapp/cli",
  "version": "0.2.0",
  "description": "TaskFlow command-line interface — drive your tasks from the terminal.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "taskflow": "./dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc -p tsconfig.json --watch",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "prepare": "npm run build",
    "prepublishOnly": "npm run typecheck && npm run build"
  },
  "engines": {
    "node": ">=18.17.0"
  },
  "keywords": [
    "taskflow",
    "cli",
    "task-manager"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/aristidekamara/taskflow-cli.git"
  },
  "bugs": {
    "url": "https://github.com/aristidekamara/taskflow-cli/issues"
  },
  "dependencies": {
    "@inquirer/prompts": "^5.0.0",
    "@taskflowapp/sdk": "^0.2.0",
    "chalk": "^5.3.0",
    "commander": "^12.1.0"
  },
  "devDependencies": {
    "@types/node": "^20.16.5",
    "typescript": "^5.6.2"
  }
}
